{
  "name": "cms-ts",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "typecheck": "tsc --noEmit",
    "dev": "bun --watch ./src/index.ts",
    "build": "bun run typecheck && bun build ./src/index.ts --minify --external express --outdir ./dist",
    "start": "bun ./dist/index.js",
    "clean": "rm -rf dist && echo 'Cartella dist eliminata.'",
    "compile": "bun build --compile --minify --target=bun-windows-x64 ./src/index.ts --outfile ./dist/cms-app",
    "initdb": "bun ./src/db/index.ts"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/cookie-parser": "^1.4.10",
    "@types/node": "^25.9.1"
  },
  "peerDependencies": {
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@types/express": "^5.0.6",
    "argon2": "^0.44.0",
    "cookie-parser": "^1.4.7",
    "express": "^5.2.1",
    "jose": "^6.2.3",
    "mysql2": "^3.22.4",
    "zod": "^4.4.3"
  }
}