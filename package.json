{
  "name": "cms-ts",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "typecheck": "tsc --noEmit",
    "dev": "bun --watch ./src/index.ts",
    "build": "bun run typecheck && bun build ./src/index.ts --minify --external express --outdir ./dist",
    "start": "bun ./dist/index.js",
    "clean": "rm -rf dist && echo 'Cartella dist eliminata.'"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14"
  },
  "peerDependencies": {
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@types/express": "^5.0.6",
    "express": "^5.2.1",
    "zod": "^4.4.3"
  }
}